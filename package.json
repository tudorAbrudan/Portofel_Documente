{
  "name": "app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "expo": {
    "autolinking": {
      "nativeModulesDir": "./modules"
    }
  },
  "scripts": {
    "start": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios --device \"00008110-001E74AC0A52801E\"",
    "web": "expo start --web",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json}\"",
    "prebuild": "expo prebuild --clean",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/__tests__/setup.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1",
      "^expo-file-system/legacy$": "<rootDir>/__mocks__/expo-file-system-legacy.js",
      "^react-native-nitro-modules$": "<rootDir>/__mocks__/react-native-nitro-modules.js",
      "^react-native-cloud-storage$": "<rootDir>/__mocks__/react-native-cloud-storage.js",
      "^@noble/ciphers/aes(\\.js)?$": "<rootDir>/node_modules/@noble/ciphers/aes.js",
      "^@noble/hashes/pbkdf2(\\.js)?$": "<rootDir>/node_modules/@noble/hashes/pbkdf2.js",
      "^@noble/hashes/sha2(\\.js)?$": "<rootDir>/node_modules/@noble/hashes/sha2.js"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|pako|@noble/.*)"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/.worktrees/"
    ]
  },
  "dependencies": {
    "@noble/ciphers": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "@react-navigation/native": "^7.1.28",
    "expo": "~55.0.4",
    "expo-build-properties": "~55.0.10",
    "expo-calendar": "~55.0.14",
    "expo-clipboard": "~55.0.9",
    "expo-constants": "~55.0.7",
    "expo-crypto": "~55.0.14",
    "expo-device": "~55.0.15",
    "expo-document-picker": "~55.0.8",
    "expo-file-system": "~55.0.10",
    "expo-font": "~55.0.4",
    "expo-image-manipulator": "^55.0.10",
    "expo-image-picker": "~55.0.10",
    "expo-linear-gradient": "~55.0.13",
    "expo-linking": "~55.0.7",
    "expo-local-authentication": "~55.0.8",
    "expo-notifications": "~55.0.10",
    "expo-print": "~55.0.8",
    "expo-router": "~55.0.3",
    "expo-secure-store": "~55.0.8",
    "expo-sharing": "~55.0.11",
    "expo-splash-screen": "~55.0.10",
    "expo-sqlite": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-store-review": "^55.0.13",
    "expo-symbols": "~55.0.4",
    "expo-web-browser": "~55.0.9",
    "jszip": "^3.10.1",
    "llama.rn": "^0.12.0-rc.8",
    "pdf-renderer": "file:./modules/pdf-renderer",
    "pdfjs-dist": "^5.5.207",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-cloud-storage": "^3.0.0",
    "react-native-nitro-modules": "^0.35.4",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.16.0",
    "react-native-worklets": "0.7.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/jszip": "^3.4.0",
    "@types/react": "~19.2.2",
    "eslint": "^8.57.0",
    "eslint-config-expo": "~8.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.2.5",
    "typescript": "~5.9.2"
  },
  "private": true
}
